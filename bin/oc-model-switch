#!/usr/bin/env bash
# oc-model-switch — Quick model swap (standalone, no .bashrc dependency)
# Reads the registry, stops llama-server, starts the new profile.
set -euo pipefail

LLM_PORT="${LLM_PORT:-8081}"
LLM_REGISTRY="${LLM_REGISTRY:-$HOME/.llm/models.conf}"
LLAMA_MODEL_DIR="${LLAMA_MODEL_DIR:-$HOME/llama.cpp/models}"
LLAMA_SERVER_BIN="${LLAMA_SERVER_BIN:-$HOME/llama.cpp/build/bin/llama-server}"
ACTIVE_LLM_FILE="/dev/shm/active_llm"
LLM_LOG_FILE="/dev/shm/llama-server.log"
LLAMA_GPU_LAYERS="${LLAMA_GPU_LAYERS:-33}"
LLAMA_CPU_THREADS="${LLAMA_CPU_THREADS:-12}"
LLAMA_CTX_SIZE="${LLAMA_CTX_SIZE:-4096}"

RST=$'\e[0m'; GRN=$'\e[32m'; RED=$'\e[31m'; YEL=$'\e[33m'; DIM=$'\e[90m'

profile="${1:-}"
if [[ -z "$profile" ]]; then
    echo "Usage: oc-model-switch <profile>"
    echo ""
    echo "Available profiles:"
    if [[ -f "$LLM_REGISTRY" ]]; then
        while IFS='|' read -r p n s pr f _rest; do
            [[ "$p" == "profile" || -z "$p" ]] && continue
            printf "  %-12s %s (%s, %s)\n" "$p" "$n" "$s" "$pr"
        done < "$LLM_REGISTRY"
    fi
    exit 1
fi

# Look up profile
entry=$(awk -F'|' -v p="$profile" '$1 == p' "$LLM_REGISTRY" 2>/dev/null)
if [[ -z "$entry" ]]; then
    echo "${RED}Error:${RST} Profile '$profile' not found in $LLM_REGISTRY"
    exit 1
fi

IFS='|' read -r prof friendly size proc file m_gpu m_ctx m_threads <<< "$entry"
model_path="$LLAMA_MODEL_DIR/$file"

if [[ ! -f "$model_path" ]]; then
    echo "${RED}Error:${RST} Model file '$file' not found at $model_path"
    exit 1
fi

# Resolve per-model params
use_gpu="${m_gpu:-$LLAMA_GPU_LAYERS}"
use_ctx="${m_ctx:-$LLAMA_CTX_SIZE}"
use_threads="${m_threads:-$LLAMA_CPU_THREADS}"

# Stop existing
echo "${YEL}Stopping existing llama-server...${RST}"
pkill -f llama-server 2>/dev/null || true
sleep 1

# Build command
cmd=("$LLAMA_SERVER_BIN" "-m" "$model_path" "--port" "$LLM_PORT" "--host" "127.0.0.1")
cmd+=("--ctx-size" "$use_ctx" "--mlock")
cmd+=("--batch-size" "512" "--ubatch-size" "512" "--cont-batching")
if [[ "$proc" == "gpu" ]]; then
    cmd+=("--n-gpu-layers" "$use_gpu" "--flash-attn")
else
    cmd+=("--threads" "$use_threads")
fi

echo "${YEL}Starting $friendly ($size) on $proc...${RST}"
nohup "${cmd[@]}" > "$LLM_LOG_FILE" 2>&1 &

echo "$prof|$friendly|$size|$proc" > "${ACTIVE_LLM_FILE}.tmp" \
    && mv "${ACTIVE_LLM_FILE}.tmp" "$ACTIVE_LLM_FILE"

# Wait for health
for i in {1..30}; do
    if curl -sf "http://127.0.0.1:${LLM_PORT}/health" >/dev/null 2>&1; then
        echo "${GRN}Online:${RST} $friendly on port $LLM_PORT"
        # Update OpenClaw provider if gateway is running
        OC_PORT="${OC_PORT:-18789}"
        if curl -sf "http://127.0.0.1:${OC_PORT}/api/health" -o /dev/null 2>/dev/null; then
            openclaw config set provider.model "$friendly" 2>/dev/null \
                && echo "${DIM}OpenClaw provider updated to $friendly${RST}"
        fi
        exit 0
    fi
    sleep 1
done

echo "${RED}Timeout:${RST} Server did not become healthy within 30s. Check $LLM_LOG_FILE"
exit 1
