#!/usr/bin/env bash
# oc-model-status — Quick LLM model status check (standalone, no .bashrc dependency)
# Reads /dev/shm state files and queries llama-server health directly.
set -euo pipefail

LLM_PORT="${LLM_PORT:-8081}"
ACTIVE_LLM_FILE="/dev/shm/active_llm"
LLM_TPS_CACHE="/dev/shm/last_tps"

# Colors
RST=$'\e[0m'; GRN=$'\e[32m'; RED=$'\e[31m'; YEL=$'\e[33m'; DIM=$'\e[90m'

# Active model
if [[ -f "$ACTIVE_LLM_FILE" ]]; then
    IFS='|' read -r prof name size proc < "$ACTIVE_LLM_FILE"
    echo "${GRN}Model:${RST} $name ($size) [profile: $prof, processor: $proc]"
else
    echo "${YEL}Model:${RST} No active model registered"
fi

# Health
if ss -tlnp 2>/dev/null | grep -q ":${LLM_PORT} " && \
   curl -sf "http://127.0.0.1:${LLM_PORT}/health" >/dev/null 2>&1; then
    echo "${GRN}API:${RST}   ONLINE (port $LLM_PORT)"
else
    echo "${RED}API:${RST}   OFFLINE"
fi

# Last TPS
if [[ -f "$LLM_TPS_CACHE" ]]; then
    echo "${DIM}TPS:${RST}   $(< "$LLM_TPS_CACHE")"
else
    echo "${DIM}TPS:${RST}   Untested"
fi
